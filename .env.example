# Production environment for docker-compose (copy to .env on the SERVER).
# docker-compose reads this file automatically; it is git-ignored.
#
#   cp .env.example .env   &&   edit the values below

# Public port on the host that maps to the container's :4000
HOST_PORT=4000

# First-run admin account, seeded into SQLite only when the users table is
# empty. CHANGE THIS before first launch, and change the password again from
# the Users page after logging in.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# x264 speed/quality trade-off. Lighter = faster CPU, lower quality.
# ultrafast | superfast | veryfast | faster | fast | medium
X264_PRESET=veryfast

# HLS segment length (seconds) and how many segments to keep in the live window
HLS_TIME=4
HLS_LIST_SIZE=6
