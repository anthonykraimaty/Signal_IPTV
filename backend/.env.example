# Port the backend listens on
PORT=4000

# First-run admin account, seeded into SQLite only when the users table is empty.
# Log in with these, then create all other users from the admin page.
# CHANGE THESE before first launch — and change the password again after logging in.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Path to the ffmpeg binary (leave as "ffmpeg" if it is on PATH)
FFMPEG_PATH=ffmpeg

# x264 speed/quality trade-off. Lighter = faster CPU, lower quality.
# ultrafast | superfast | veryfast | faster | fast | medium
X264_PRESET=veryfast

# HLS segment length (seconds) and how many segments to keep in the live window
HLS_TIME=4
HLS_LIST_SIZE=6
